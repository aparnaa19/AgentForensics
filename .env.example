# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# OpenAI API key (required for OpenAI-based agents)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API key (required for Anthropic-based agents)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional tuning ────────────────────────────────────────────────────────

# Injection detection threshold (0.0–1.0, default: 0.25)
# AF_INJECT_THRESHOLD=0.25

# Sliding-window size in turns (default: 3, set to 0 to disable)
# AF_WINDOW_SIZE=3

# Disable the ML classifier and use heuristics only (useful for low-latency)
# AF_DISABLE_ML=false

# Custom path to the DistilBERT model directory
# AF_MODEL_PATH=agentforensics/model

# Webhook URL for real-time injection alerts
# AF_ALERT_WEBHOOK=https://your-webhook-url.com/alert

# Trace storage directory (default: .af_traces)
# AF_TRACE_DIR=.af_traces

# Proxy target URL (default: http://localhost:11434)
# AF_PROXY_TARGET=http://localhost:11434

# Proxy listen port (default: 9000)
# AF_PROXY_PORT=9000
